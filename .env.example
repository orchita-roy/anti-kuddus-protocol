# Application
NEXT_PUBLIC_APP_NAME=Anti-Kuddus Protocol
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-characters

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/anti_kuddus_protocol
MONGODB_DB_NAME=anti_kuddus_protocol

# Identity protection
ROLL_LOOKUP_SECRET=replace-with-a-long-random-string-at-least-32-characters
COMPLAINT_HMAC_SECRET=replace-with-a-different-long-random-string-at-least-32-characters

# Gemini
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Pusher (optional; polling is the fallback)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

MAX_UPLOAD_MB=5
ENABLE_DEMO_AI_FALLBACK=true
